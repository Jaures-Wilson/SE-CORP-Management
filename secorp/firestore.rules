rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /students/{studentId} {
      allow read: if true;
      allow write: if false;
    }
    match /dossiers/{id} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if false;
    }
    match /cni/{id} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if false;
    }
    match /caisse/{id} {
      allow read: if true;
      allow write: if true;
    }
    match /config/{id} {
      allow read: if true;
      allow write: if true;
    }
  }
}
